# ---- gexmonitorapi 配置示例 ----
# 复制为 .env 后修改。生产环境务必改掉 API_TOKEN。

# 所有 /v1 端点都要求 Authorization: Bearer <API_TOKEN>
# 生成示例：python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=dev-token-change-me

# 后台自动刷新间隔（秒）。默认 1800 = 30 分钟（减少无头浏览器内存尖峰）
REFRESH_INTERVAL_SECONDS=1800

# 单次抓取超时（秒）
REQUEST_TIMEOUT_SECONDS=45

# 最近一次成功缓存的持久化路径
CACHE_FILE=.cache/gexmonitorapi/cache.json

# 抓取用 User-Agent
USER_AGENT=gexmonitorapi/0.1 (+https://gexmonitor.com public page metric monitor)

# 是否开启后台周期刷新
ENABLE_BACKGROUND_REFRESH=true

# 启动时是否立即抓取一次（首屏冷启动会慢，生产可设 true）
REFRESH_ON_STARTUP=false

# --- 浏览器抓取 ---
# 面板是 websocket 推送、DOM 加载后才渲染，固定等待这么多毫秒再取文本（抓不到就调大）
BROWSER_WAIT_MS=12000
# headless Chromium 以非 root 在受限主机起不来时设 true（加 --no-sandbox）
BROWSER_NO_SANDBOX=false
# 等 network idle（默认 false：本站长连 websocket，idle 永远不到）
BROWSER_NETWORK_IDLE=false
