# 复制到 /etc/gexmonitorapi.env，改掉 API_TOKEN，然后 chmod 600。
# systemd EnvironmentFile 格式：每行 KEY=VALUE，不要加引号、不要写 export。

# 强 Token：ssh 到服务器后用 `python3 -c "import secrets;print(secrets.token_urlsafe(32))"` 生成
API_TOKEN=REPLACE_WITH_A_STRONG_RANDOM_TOKEN

# 30 分钟一次,减少无头浏览器的内存尖峰频率(小内存机器建议保持或更长)
REFRESH_INTERVAL_SECONDS=1800
REQUEST_TIMEOUT_SECONDS=45

# 缓存持久化到 app 目录下（确保运行用户对该目录可写）
CACHE_FILE=/home/ubuntu/gexmonitorapi/.cache/cache.json

USER_AGENT=gexmonitorapi/0.1 (+https://gexmonitor.com public page metric monitor)

# 后台周期刷新：开。启动后台任务会立刻先抓一轮，再按间隔循环。
ENABLE_BACKGROUND_REFRESH=true
# 启动时阻塞式抓一轮：建议关，避免拖慢服务就绪（后台任务无论如何会立即抓一次）。
REFRESH_ON_STARTUP=false

# --- 浏览器抓取 ---
# 面板是 websocket 推送、DOM 加载后才渲染，固定等待这么多毫秒再取文本。抓不到就调大。
BROWSER_WAIT_MS=12000
# 锁死 user namespace 的主机上 headless Chromium 起不来时设 true（见故障排查 解法 B）
BROWSER_NO_SANDBOX=false
