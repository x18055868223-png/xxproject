# Bitnami Apache alias for the signal audit static frontend.
# Include this file from /opt/bitnami/apache/conf/httpd.conf, or copy it to a
# Bitnami include/vhosts directory if that Apache config already includes one.

Alias /signal-audit/ "/opt/signal-audit/"

<Directory "/opt/signal-audit">
    Options -Indexes +FollowSymLinks
    AllowOverride None
    Require all granted
</Directory>

<Directory "/opt/signal-audit/signal_cards">
    Header set Cache-Control "no-store"
    Options -Indexes +FollowSymLinks
    AllowOverride None
    Require all granted
</Directory>

RedirectMatch 301 ^/signal-audit$ /signal-audit/
