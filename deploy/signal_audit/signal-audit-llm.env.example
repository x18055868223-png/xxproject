# Local server-only config. Copy/edit as /etc/signal-audit/llm.env.
# Keep this file mode 0600 and never commit the real key.
# Preferred primary key: low-cost Gemini 3.5 Flash account.
GEMINI_3_5_FLASH_API_KEY=
# Fallback key: normal paid-tier account. Leave empty if unavailable.
GEMINI_PAID_API_KEY=
# Backward-compatible single-key fallback; optional when the two keys above are set.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
LLM_REVIEW_LIMIT=2
LLM_REVIEW_TIMEOUT=60
JSONL_SOURCE=/home/bitnami/fmz2/logs/storage/668422/demo/logs/signal_review.jsonl
LLM_REVIEWS_SOURCE=/opt/signal-audit-tools/signal_llm_reviews.jsonl
